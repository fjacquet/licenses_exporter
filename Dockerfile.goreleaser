# Release image: copies the prebuilt GoReleaser binary (no builder stage). Built in
# CI with open egress, so apk is tolerated here. Non-root USER is mandatory.
FROM alpine:3.24
RUN apk add --no-cache ca-certificates && adduser -D -u 10001 licenses
COPY licenses_exporter /usr/local/bin/licenses_exporter
COPY config.yaml /etc/licenses_exporter/config.yaml
USER 10001
EXPOSE 9105
ENTRYPOINT ["/usr/local/bin/licenses_exporter"]
CMD ["--config", "/etc/licenses_exporter/config.yaml"]
